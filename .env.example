# ============================================
# VPN SHIELD CONFIGURATION
# ============================================
# SECURITY WARNING: Change ALL default values before deploying to production!
# Never commit the actual .env file to version control!

# Database Configuration
# REQUIRED: Must be set for security
DB_PASSWORD=your_secure_password_here_CHANGE_THIS
DB_NAME=vpnshield
DB_USER=vpnshield
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here_CHANGE_THIS

# JWT Configuration
# REQUIRED: Must be at least 32 characters long
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long_CHANGE_THIS

# Admin Credentials (First User)
# REQUIRED: Must be set for security
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_REQUIRED
ADMIN_EMAIL=admin@example.com

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
# SECURITY: Set specific origins in production, not "*"
# Example: ALLOWED_ORIGINS=https://panel.yourdomain.com,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Domain Configuration
DOMAIN=your-domain.com
PANEL_DOMAIN=panel.your-domain.com

# Cloudflare (for domain fronting)
CLOUDFLARE_API_TOKEN=your_cloudflare_token
CLOUDFLARE_ZONE_ID=your_zone_id

# REALITY Configuration (Xray)
REALITY_DEST=www.microsoft.com:443
REALITY_SERVER_NAMES=www.microsoft.com,www.bing.com
XRAY_PATH=/usr/local/bin/xray
XRAY_CONFIG_PATH=./xray-configs
XRAY_LOG_PATH=/var/log/vpn-shield/xray.log

# Hysteria2 Configuration
HYSTERIA_PORT=36712
HYSTERIA_OBFS_PASSWORD=your_obfs_password_CHANGE_THIS
HYSTERIA_PATH=/usr/local/bin/hysteria
HYSTERIA_CONFIG_PATH=./hysteria-configs
HYSTERIA_LOG_PATH=/var/log/vpn-shield/hysteria.log

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/vpn-shield/app.log
